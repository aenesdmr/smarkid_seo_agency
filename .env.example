# Google Gemini API Anahtarınız (Yapay Zeka yazarımız için)
# https://aistudio.google.com/ adresinden ücretsiz veya düşük maliyetli alabilirsiniz.
GEMINI_API_KEY=your_gemini_api_key_here

# Framer Server API Anahtarınız
# Framer projenizde Site Settings -> API Keys kısmından üretebilirsiniz.
FRAMER_API_KEY=your_framer_api_key_here

# Güncellemek istediğiniz Framer projesinin adresi
# Tarayıcı çubuğundaki proje adresidir (Örn: https://framer.com/projects/smartkid-agency--7uiv3ZV...)
FRAMER_PROJECT_URL=https://framer.com/projects/your-project-id-here

# Makalelerin ekleneceği CMS Koleksiyonunun (Collection) ID'si
# Framer CMS panelinde ilgili koleksiyonun ayarlarına girerek bu ID'yi bulabilirsiniz.
FRAMER_COLLECTION_ID=your_cms_collection_id_here
